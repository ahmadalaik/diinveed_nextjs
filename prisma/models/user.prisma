enum UserRole {
    user
    admin
}

model User {
    id        String   @id @default(cuid())
    name      String
    email     String   @unique
    password  String
    role      UserRole @default(user)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    invitation Invitation?
    sessions   Session[]

    @@map("users")
}
