model Gift {
    id            String   @id @default(uuid())
    invitationId  String
    provider      String
    accountName   String
    accountNumber String
    order         Int
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    invitation Invitation @relation(fields: [invitationId], references: [id])

    @@index([invitationId])
    @@map("gifts")
}
