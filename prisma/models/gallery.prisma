model Gallery {
    id            String   @id @default(cuid())
    invitationId  String
    imageUrl      String
    imagePublicId String
    order         Int
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    invitation Invitation @relation(fields: [invitationId], references: [id])

    @@index([invitationId, imagePublicId])
    @@map("galleries")
}
