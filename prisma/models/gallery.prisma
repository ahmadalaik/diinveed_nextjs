model Gallery {
    id           String   @id @default(uuid())
    invitationId String
    imageUrl     String
    imageUrlId   String
    order        Int
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    invitation Invitation @relation(fields: [invitationId], references: [id])

    @@index([invitationId])
    @@map("galleries")
}
