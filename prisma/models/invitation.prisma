enum InvitationStatus {
    active
    inactive
}

model Invitation {
    id        String   @id @default(uuid())
    userId    String   @unique
    slug      String   @db.VarChar(255)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id])

    @@index([slug])
    @@map("invitations")
}
