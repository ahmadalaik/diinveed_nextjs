model Event {
    id           String   @id @default(uuid())
    invitationId String
    title        String
    date         DateTime
    startTime    DateTime
    endTime      DateTime
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    invitation Invitation @relation(fields: [invitationId], references: [id])

    @@index([invitationId])
    @@map("events")
}
